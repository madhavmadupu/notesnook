{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run linc)",
      "Bash(npm run linc:*)",
      "Bash(npm run prettier)",
      "Bash(npm run test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run start:*)",
      "Bash(npm run tx *)",
      "Bash(node scripts/*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git add:*)",
      "Bash(git restore --staged:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf:*)",
      "Bash(npm publish:*)"
    ]
  }
}
